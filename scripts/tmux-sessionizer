#!/usr/bin/env bash

if [[ $# -eq 1 ]]; then
    selected=$1
else
    directories=()

    if [[ -d ~/dev ]]; then
        directories+=(~/dev)
    fi

    if [[ -d ~/euc ]]; then
        directories+=(~/euc)
    fi

    if [[ -d ~/net ]]; then
        directories+=(~/net)
    fi

    find_results=""

    for dir in "${directories[@]}"; do
        for repo in "$dir"/*/; do
            if [[ "$(git -C "$repo" rev-parse --is-bare-repository 2>/dev/null)" == "true" ]]; then
                repo_abs=$(cd "$repo" && pwd)
                worktrees=$(git -C "$repo" worktree list --porcelain | grep '^worktree ' | sed 's/^worktree //' | grep -v "^${repo_abs}$")
                if [[ -n $worktrees ]]; then
                    find_results+=$'\n'"$worktrees"
                fi
            else
                find_results+=$'\n'"$repo"
            fi
        done
    done
    find_results+=$'\n'"$HOME/.config"

    if [[ -d ~/.cursor ]]; then
      find_results+=$'\n'"$HOME/.cursor"
    fi

    if [[ -d ~/.claude ]]; then
      find_results+=$'\n'"$HOME/.claude"
    fi

    # Add the root directories too
    for dir in "${directories[@]}"; do
        find_results+=$'\n'"$dir"
    done

    selected=$(echo "$find_results" | fzf)
fi

if [[ -z $selected ]]; then
    exit 0
fi

parent_dir=$(basename "$(dirname "$selected")")
selected_dir=$(basename "$selected")

selected_name=$(echo "${parent_dir}_${selected_dir}" | tr . _)

tmux_running=$(pgrep tmux)

if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
    tmux new-session -s $selected_name -c $selected 'nvim'
    exit 0
fi

if ! tmux has-session -t=$selected_name 2> /dev/null; then
    tmux new-session -ds $selected_name -c $selected 'nvim'
fi

if [[ -z $TMUX ]]; then
    tmux attach -t $selected_name
else
    tmux switch-client -t $selected_name
fi
